<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <main class="form-page">
    <div class="form-box">
      <h1>Login</h1>

      <%
        const loginSuccess = Array.isArray(success_msg)
          ? success_msg
          : (success_msg ? [success_msg] : []);
        const loginErrors = Array.isArray(error_msg)
          ? error_msg
          : (error_msg ? [error_msg] : []);
      %>

      <% if (loginSuccess.length || loginErrors.length) { %>
        <div class="form-alerts" aria-live="polite">
          <% loginSuccess.forEach((message) => { %>
            <p class="alert alert-success"><%= message %></p>
          <% }) %>
          <% loginErrors.forEach((message) => { %>
            <p class="alert alert-error"><%= message %></p>
          <% }) %>
        </div>
      <% } %>

      <form action="/auth/login" method="POST">
        <input type="email" name="email" placeholder="Email" required>
        <input type="password" name="password" placeholder="Password" required>
        <button type="submit">Login</button>
      </form>

      <p class="form-footer">
        Don’t have an account? <a href="/auth/register">Register</a>
      </p>
    </div>
  </main>
</body>
</html>
