<li class="item-card"
    data-title="<%= (item.title || '').toLowerCase() %>"
    data-description="<%= (item.description || '').toLowerCase() %>"
    data-price="<%= item.price || 0 %>"
    data-condition="<%= (item.condition || '').toLowerCase() %>"
    data-platform="<%= (item.platform || '').toLowerCase() %>"
    data-available="<%= item.available ? 'true' : 'false' %>">
    <div class="card-grid">
      
      <!-- Left Side: Thumbnail -->
      <div class="item-thumb">
        <% if (item.imageLinks && item.imageLinks[0]) { %>
          <img src="<%= item.imageLinks[0] %>" alt="Item Image">
        <% } else { %>
          <div class="no-img">No Image</div>
        <% } %>
      </div>
  
      <!-- Center: Info -->
      <div class="item-info">
        <p class="title">
          <a href="<%= item.link %>" target="_blank" rel="noopener noreferrer">
            <%= item.title %> <span style="opacity:0.4">&#x1F517;</span>
          </a>
        </p>

        <div class="badge-row">
          <% if (item.platform) { %>
            <span class="badge badge-platform"><%= item.platform %></span>
          <% } %>
          <span class="badge <%= item.available ? 'badge-available' : 'badge-unavailable' %>">
            <%= item.available ? 'Available' : 'Sold' %>
          </span>
        </div>

        <dl class="meta-grid">
          <dt>Price</dt>
          <dd><%= item.price || 'N/A' %></dd>
          <dt>Condition</dt>
          <dd><%= item.condition || 'N/A' %></dd>
          <dt>Location</dt>
          <dd><%= item.location || 'N/A' %></dd>
        </dl>

        <% if (item.description) { %>
          <p class="item-description"><%= item.description %></p>
        <% } %>

        <% if (showCategories && categories) { %>
          <p style="margin-top:0.5rem">
            <% categories.forEach(cat => {
                const match = cat.items.some(i => {
                  const iId = i.item ? i.item._id : i._id;
                  return iId.toString() === item._id.toString();
                });
                if (cat.name !== 'All Listings' && match) { %>
              <span class="category-label"><%= cat.name %></span>
            <% }}) %>
          </p>
        <% } %>

        <% if (showAddedBy && addedBy && addedBy.username) { %>
          <p class="added-by-badge">
            added by <%= user && addedBy._id.toString() === user._id.toString() ? "You" : addedBy.username %>
          </p>
        <% } %>
      </div>
  
      <!-- Kebab Menu -->
      <div class="kebab-menu">
        <button type="button" class="kebab-btn" aria-label="Actions">
          <svg class="kebab-icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
            <circle cx="10" cy="4" r="2.3" fill="currentColor"/>
            <circle cx="10" cy="10" r="2.3" fill="currentColor"/>
            <circle cx="10" cy="16" r="2.3" fill="currentColor"/>
          </svg>
        </button>
        <div class="kebab-dropdown" style="display:none;">

          <% if (allowEdit && categories) { %>
            <%
              const catCount = categories.filter(c =>
                c.name !== 'All Listings' &&
                c.items.some(i => {
                  const iId = i.item ? i.item._id : i._id;
                  return iId.toString() === item._id.toString();
                })
              ).length;
            %>
            <div class="category-picker">
              <button type="button" class="picker-toggle" data-item-id="<%= item._id %>">
                <span>Assign categories</span>
                <span class="cat-count"><%= catCount %></span>
              </button>
              <div class="picker-dropdown" style="display:none;">
                <form class="category-checkbox-form" data-item-id="<%= item._id %>">
                  <% categories.forEach(cat => {
                      if (cat.name !== 'All Listings') {
                        const isChecked = cat.items.some(i => {
                          const iId = i.item ? i.item._id : i._id;
                          return iId.toString() === item._id.toString();
                        });
                  %>
                    <label class="checkbox-item">
                      <input type="checkbox" name="categories" value="<%= cat._id %>" <%= isChecked ? 'checked' : '' %>>
                      <span><%= cat.name %></span>
                    </label>
                  <% }}) %>
                  <button type="submit" class="save-btn">Save</button>
                </form>
              </div>
            </div>
          <% } %>

          <% if (categoryId && user && (isOwner || (addedBy && addedBy._id.toString() === user._id.toString()))) { %>
            <hr class="kebab-divider">
            <form method="POST" action="/categories/<%= categoryId %>/remove-item">
              <input type="hidden" name="itemId" value="<%= item._id %>">
              <button type="submit" class="kebab-action kebab-action--danger" onclick="return confirm('Remove this listing from this category?')">
                Remove from category
              </button>
            </form>
          <% } else if (!categoryId && allowDelete && isOwner) { %>
            <hr class="kebab-divider">
            <form method="POST" action="/items/<%= item._id %>?_method=DELETE">
              <button type="submit" class="kebab-action kebab-action--danger" onclick="return confirm('Are you sure you want to delete this listing?')">
                Delete listing
              </button>
            </form>
          <% } %>

        </div>
      </div>
    </div>
  </li>
  
