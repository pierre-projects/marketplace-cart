<!DOCTYPE html>
<html>
<head>
  <title>My Categories</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% const currentPage = 'categories'; %>
  <%- include('../partials/navbar') %>

  <main class="container">
    <%- include('../partials/flash-alert') %>

    <div class="page-header">
      <h1>My Categories</h1>
      <div class="categories-header-actions">
        <form action="/categories/create" method="POST" class="create-category-form">
          <input type="text" name="name" placeholder="New category name" required>
          <button type="submit" class="btn-primary">Create category</button>
        </form>
      </div>
    </div>

    <!-- Your Categories -->
    <% const userCategories = categories.filter(c => c.name !== 'All Listings'); %>

    <% if (userCategories.length === 0) { %>
      <div class="empty-state">
        <p>You haven't created any categories yet.</p>
        <p class="muted">Create one above to start organizing your listings.</p>
      </div>
    <% } else { %>
      <div class="category-grid">
        <% userCategories.forEach(category => { %>
          <%
            const previewItems = category.items
              .filter(ci => ci.item && ci.item.imageLinks && ci.item.imageLinks.length > 0)
              .slice(0, 3);
            const availCount = category.items.filter(ci => ci.item && ci.item.available).length;
          %>
          <div class="category-card">
            <a href="/categories/<%= category._id %>" class="category-preview-link" tabindex="-1" aria-hidden="true">
              <div class="category-preview">
                <% if (previewItems.length === 0) { %>
                  <div class="category-preview-empty">No preview yet</div>
                <% } else { %>
                  <% previewItems.forEach(ci => { %>
                    <div class="category-preview-slot">
                      <img src="<%= ci.item.imageLinks[0] %>" alt="<%= ci.item.title %>" class="category-preview-img" loading="lazy">
                    </div>
                  <% }) %>
                  <% for (let i = previewItems.length; i < 3; i++) { %>
                    <div class="category-preview-slot category-preview-slot--empty"></div>
                  <% } %>
                <% } %>
              </div>
            </a>
            <div class="category-card-footer">
              <a href="/categories/<%= category._id %>" class="category-card-link">
                <h3 class="category-name"><%= category.name %></h3>
                <div class="category-meta-row">
                  <span class="category-meta"><%= category.items.length %> item<%= category.items.length !== 1 ? 's' : '' %></span>
                  <% if (category.items.length > 0) { %>
                    <span class="category-meta-sep">·</span>
                    <span class="category-meta"><%= availCount %> available</span>
                  <% } %>
                </div>
              </a>
              <button type="button" class="manage-btn"
                data-id="<%= category._id %>"
                data-name="<%= category.name %>">
                Manage
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Shared With Me -->
    <% if (sharedCategories && sharedCategories.length > 0) { %>
      <h2 class="section-title">Shared With Me</h2>
      <div class="category-grid">
        <% sharedCategories.forEach(category => { %>
          <%
            const previewItems = category.items
              .filter(ci => ci.item && ci.item.imageLinks && ci.item.imageLinks.length > 0)
              .slice(0, 3);
            const availCount = category.items.filter(ci => ci.item && ci.item.available).length;
          %>
          <div class="category-card category-card--shared">
            <a href="/categories/<%= category._id %>" class="category-preview-link" tabindex="-1" aria-hidden="true">
              <div class="category-preview">
                <% if (previewItems.length === 0) { %>
                  <div class="category-preview-empty">No preview yet</div>
                <% } else { %>
                  <% previewItems.forEach(ci => { %>
                    <div class="category-preview-slot">
                      <img src="<%= ci.item.imageLinks[0] %>" alt="<%= ci.item.title %>" class="category-preview-img" loading="lazy">
                    </div>
                  <% }) %>
                  <% for (let i = previewItems.length; i < 3; i++) { %>
                    <div class="category-preview-slot category-preview-slot--empty"></div>
                  <% } %>
                <% } %>
              </div>
            </a>
            <div class="category-card-footer">
              <a href="/categories/<%= category._id %>" class="category-card-link">
                <div class="category-name-row">
                  <span class="shared-badge">Shared</span>
                  <h3 class="category-name"><%= category.name %></h3>
                </div>
                <div class="category-meta-row">
                  <span class="category-meta"><%= category.items.length %> item<%= category.items.length !== 1 ? 's' : '' %></span>
                  <% if (category.items.length > 0) { %>
                    <span class="category-meta-sep">·</span>
                    <span class="category-meta"><%= availCount %> available</span>
                  <% } %>
                </div>
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

  <!-- Manage Category Modal -->
  <div id="manageCategoryModal" class="modal-overlay" style="display:none;">
    <div class="modal-content modal-sm">
      <div class="modal-header">
        <h2>Manage Category</h2>
        <button type="button" class="modal-close">&times;</button>
      </div>
      <div class="modal-body">
        <form id="renameForm" class="modal-form">
          <label for="newName">Rename</label>
          <div class="input-group">
            <input type="text" id="newName" name="name" required>
            <button type="submit" class="btn-primary">Save</button>
          </div>
        </form>
        <hr class="modal-divider">
        <div class="danger-zone">
          <p class="danger-label">Danger Zone</p>
          <button type="button" id="deleteBtn" class="btn-danger">Delete Category</button>
          <p class="danger-warning">This will remove the category but not the items.</p>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/categories.js"></script>
</body>
</html>
